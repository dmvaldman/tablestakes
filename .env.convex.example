# Copy to `.env.convex` (gitignored), fill in, then run `npm run convex:env`.
# Uploaded to the Convex deployment env; read by functions server-side only.
# Do NOT put these in .env / .env.local — VITE_-prefixed vars leak to the client.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# tried if the primary is overloaded (503/429)
GEMINI_FALLBACK_MODEL=gemini-3.1-pro-preview
